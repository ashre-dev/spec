# ── Vendor server ──────────────────────────────────────────────────────────────
# Which vendor catalog to load (helsinki-maker-store | berlin-hacker-space)
VENDOR_ID=helsinki-maker-store

# ── Real x402 payments (Phase 5) — leave blank to stay in mock mode ────────────
# Base Sepolia RPC endpoint (e.g. from Alchemy, Infura, or Coinbase)
SEPOLIA_RPC_URL=

# Agent's EVM private key on Base Sepolia (0x-prefixed, 64 hex chars)
# Fund with testnet USDC from https://faucet.circle.com
AGENT_PRIVATE_KEY=

# ── Anthropic ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
